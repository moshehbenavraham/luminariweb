{
  "name": "luminariweb",
  "private": true,
  "version": "0.1.12",
  "description": "First-party React and Node web MUD client for LuminariMUD-compatible games with an MSDP-driven HUD and WebSocket-to-Telnet proxy.",
  "author": {
    "name": "M. Ben Avraham",
    "email": "moshehwebservices@live.com",
    "url": "https://github.com/moshehbenavraham"
  },
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moshehbenavraham/luminariweb.git"
  },
  "bugs": {
    "url": "https://github.com/moshehbenavraham/luminariweb/issues"
  },
  "homepage": "https://github.com/moshehbenavraham/luminariweb#readme",
  "keywords": [
    "luminari",
    "luminari-mud",
    "mud",
    "web-client",
    "telnet",
    "websocket",
    "msdp",
    "react",
    "vite",
    "typescript"
  ],
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "node --import tsx --test tests/*.test.ts",
    "preview": "vite preview",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ansi-to-html": "^0.7.2",
    "express": "^5.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
